# ==============================================
# Universal .gitignore (All-in-One)
# Covers: Java, Spring Boot, React, Node.js, IntelliJ, VSCode, OS files, Logs, Builds
# ==============================================

### Java ###

*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*
*.log
*.ctxt
*.hprof
*.out
*.err

# Build directories
target/
bin/
build/
out/
target/
.gradle/
.mvn/
!.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/
!backend/.mvn/wrapper/
!backend/.mvn/wrapper/maven-wrapper.properties

# Spring Boot specific
*.db
*.mv.db
*.h2.db
*.log
*.tmp
*.bak
*.swp
*.iml
*.iws
*.ipr

### Node / React ###
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Production build
build/
dist/
.next/
out/
coverage/
.cache/
.temp/
.vite/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDEs and Editors
### IntelliJ IDEA ###
.idea/
*.iml
*.iws
out/

### VS Code ###
.vscode/
.history/
*.code-workspace

# JetBrains / Eclipse / NetBeans
.classpath
.project
.settings/
.nb-gradle/
.nbproject/private/
build.xml
nb-configuration.xml

### OS / System ###
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Linux
*~
.nfs*

### Logs / Temporary ###
logs/
*.log
*.tmp
*.bak
*.swp
*.swo
*.pid
*.seed
*.pid.lock

# Crash logs
*.stackdump
*.crash

### Python Virtual Env (optional if using Python) ###
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.py.class

### Other Development Tools ###
# JetBrains Fleet
.fleet/

# Docker
docker-compose.override.yml
docker-compose.local.yml
.dockerignore
docker-data/

# Nginx / Apache / Server dumps
*.conf
*.pid

# Misc
tmp/
temp/
.cache/
.envrc
.idea_modules/
typings/
jspm_packages/
bower_components/

### OS backup files ###
*.bak
*.swp
*.swo
*.tmp
*.old

# Ensure all JetBrains/IDE artifacts are ignored recursively
**/.idea/
**/*.iml
.idea/
*.iml

# JetBrains IDE (IntelliJ, IDEA) - ignore everywhere
.idea/
**/.idea/**
*.iml
**/*.iml
*.ipr
*.iws

# Explicit frontend/backend env files
frontend/.env
frontend/.env.local
backend/.env
backend/.env.local

# IDE folders (ignore everywhere)
.idea/
.vscode/
**/.idea/**
**/.vscode/**

# JetBrains project files
*.iml
*.ipr
*.iws

